{
    "name": "keplars/email-sdk",
    "description": "Official PHP SDK for Keplars Email API - modern transactional email service with priority-based delivery",
    "type": "library",
    "license": "MIT",
    "keywords": ["keplars", "email", "transactional", "api", "sdk", "priority"],
    "authors": [
        {
            "name": "Keplars",
            "email": "support@keplars.com"
        }
    ],
    "homepage": "https://keplars.com",
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.8",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Keplars\\Email\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Keplars\\Email\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src --level=max",
        "cs": "phpcs src",
        "cs-fix": "phpcbf src"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
